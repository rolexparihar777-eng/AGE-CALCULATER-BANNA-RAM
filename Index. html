<!DOCTYPE html>
<html>
<head>
    <title>Age Calculator PRO</title>
    <style>
        body {
            background: linear-gradient(to right, #141e30, #243b55);
            font-family: Arial;
            text-align: center;
            color: white;
        }

        .box {
            background: #1f2a40;
            padding: 20px;
            margin: 50px auto;
            width: 300px;
            border-radius: 15px;
            box-shadow: 0px 0px 10px black;
        }

        input {
            width: 90%;
            padding: 10px;
            margin: 10px;
            border-radius: 8px;
            border: none;
            text-align: center;
        }

        button {
            background: #4CAF50;
            color: white;
            padding: 10px;
            width: 95%;
            border: none;
            border-radius: 10px;
            font-size: 16px;
        }

        button:hover {
            background: #45a049;
        }

        #result {
            margin-top: 15px;
            font-size: 18px;
            color: yellow;
        }
    </style>
</head>

<body>

<div class="box">
    <h2>🎂 Age Calculator</h2>

    <input type="text" id="dob" placeholder="DOB (DD-MM-YYYY)">
    <input type="text" id="today" placeholder="Today (DD-MM-YYYY)">

    <button onclick="calculateAge()">Calculate Age</button>

    <div id="result"></div>
</div>

<script>
function calculateAge() {
    let dob = document.getElementById("dob").value;
    let today = document.getElementById("today").value;

    let d1 = dob.split("-");
    let d2 = today.split("-");

    let birth = new Date(d1[2], d1[1]-1, d1[0]);
    let current = new Date(d2[2], d2[1]-1, d2[0]);

    let years = current.getFullYear() - birth.getFullYear();
    let months = current.getMonth() - birth.getMonth();
    let days = current.getDate() - birth.getDate();

    if (days < 0) {
        months--;
        days += 30;
    }

    if (months < 0) {
        years--;
        months += 12;
    }

    document.getElementById("result").innerHTML =
        "🎉 Age: " + years + " Years, " + months + " Months, " + days + " Days";
}
</script>

</body>
</html>
